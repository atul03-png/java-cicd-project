pipeline {
    agent any

    tools {
        maven 'Maven-3.9'
        jdk   'JDK-17'
    }

    environment {
        DOCKER_IMAGE    = 'hello-java'
        AWS_REGION      = 'us-east-1'
        AWS_ACCOUNT_ID  = credentials('aws-account-id')
        ECR_URI         = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${DOCKER_IMAGE}"
        SONAR_TOKEN     = credentials('sonar-token')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                sh 'mvn clean test -B'
            }
            post {
                always {
                    junit 'target/surefire-reports/**/*.xml'
                }
            }
        }

        stage('SonarQube') {
            steps {
                withSonarQubeEnv('sonarqube-server') {
                    sh """
                        mvn sonar:sonar \
                          -Dsonar.projectKey=hello-java \
                          -Dsonar.login=${SONAR_TOKEN}
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Package') {
            steps {
                sh 'mvn package -DskipTests -B'
            }
        }

        stage('Docker Build') {
            steps {
                sh "docker build -t ${ECR_URI}:${BUILD_NUMBER} ."
            }
        }

        stage('Push to ECR') {
            steps {
                withAWS(credentials: 'aws-creds', region: "${AWS_REGION}") {
                    sh """
                        aws ecr get-login-password \
                          | docker login --username AWS \
                            --password-stdin ${ECR_URI}
                        docker push ${ECR_URI}:${BUILD_NUMBER}
                        docker tag  ${ECR_URI}:${BUILD_NUMBER} ${ECR_URI}:latest
                        docker push ${ECR_URI}:latest
                    """
                }
            }
        }

        stage('Deploy') {
            steps {
                withAWS(credentials: 'aws-creds', region: "${AWS_REGION}") {
                    sh """
                        aws ecs update-service \
                          --cluster  hello-java-cluster \
                          --service  hello-java-service \
                          --force-new-deployment
                    """
                }
            }
        }
    }

    post {
        success { echo "Build #${BUILD_NUMBER} — deployed successfully" }
        failure { echo "Build #${BUILD_NUMBER} — FAILED" }
        always  { cleanWs() }
    }
}
